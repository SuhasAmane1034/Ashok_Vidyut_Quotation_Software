# ── QuoteFlow Client — Environment Variables ─────────────
# Copy this file to .env and edit values

# Leave BLANK for local/LAN development.
# The app auto-detects your IP from window.location.hostname.
# Only set this for a deployed/production build.
REACT_APP_API_URL=

# Backend port (only needed if you change the default 3001)
REACT_APP_API_PORT=3001
